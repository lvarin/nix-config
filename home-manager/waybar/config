{
    "height": 10,
    "spacing": 2,

    "modules-left": ["custom/launcher", "sway/workspaces"],
    "modules-center": ["sway/mode"],
    "modules-right": ["custom/recorder", "custom/layout", "idle_inhibitor", "tray", "pulseaudio", "battery", "clock", "custom/power"],
    "custom/layout": {
      "exec": "swaymsg -t get_inputs | jq -r '.[] | select(.type==\"keyboard\") | .xkb_active_layout_name' | head -n1 | awk '{ if ($0 ~ /English/) print \"ΏθΘυΏθΘπ\"; else if ($0 ~ /Finnish/) print \"ΏθΘτΏθΘχ\"; else print $0 }'",
      "interval": 1
    },
    "sway/workspaces": {
	    "disable-scroll": true,
	    "format": "{name}: {icon}",
      "format-icons": {
        "urgent": "ΎΒς",
        "focused": "ΎΗΤ",
        "default": "έΔζ",
        "visible": "έο╛"
	    }
    },
    "sway/mode": {
        "format": "<span style=\"italic\">{}</span>"
    },
    "sway/language": {
    "format": "{flag}{shortDescription} {variant}"
    },
    "idle_inhibitor": {
        "format": "{icon}",
        "format-icons": {
            "activated": "ΎΒχ",
            "deactivated": "ΎΒ░"
        }
    },
    "tray": {
        "icon-size": 20,
        "spacing": 7
    },
    "clock": {
	"format": "ΎΒ│  {:%b %d %a ΎΑΩ %H:%M}",
        "tooltip-format": "ΎΒ│ {:%a - %Y %b %d - w%W ΎΑΩ %H:%M:%S %z}"
    },
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}",
        "format-charging": " ΎΔπΎΘο  {capacity}%",
        "format-plugged": " ΎΘο  {capacity}%",
        "format-alt": "{time} {icon} {capacity}%",
        // "format-good": "", // An empty format will hide the module
        // "format-full": "",
        "tooltip-format": "{capacity}% - {time}",
        "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"]
    },
    "pulseaudio": {
        // "scroll-step": 1, // %, can be a float
        "format": "{icon}",
        "format-bluetooth": "{icon} (ΎΛΦ)",
        "format-bluetooth-muted": "ΎΑοx {icon} (ΎΛΦ)",
        "format-muted": "ΎΑοx",
        "format-source": "{volume}% ΎΕ░",
        "format-source-muted": "ΎΕ▒",
        "format-icons": {
            "headphone": "ΎΑξ",
            "hands-free": "ΎΨΡ",
            "headset": "ΎΑξ",
            "phone": "ΎΓΧ",
            "portable": "ΎΓΧ",
            "car": "ΎΗ╣",
            "default": ["ΎΑο", "ΎΑπ", "ΎΑρ"]
        },
        "tooltip-format": "{icon} {volume}%",
        "on-click": "pavucontrol"
    },
    "custom/power": {
      "format": "ΎΑΣ",
      // "on-click": "swaynag -t warning -m 'Power Menu Options' -b 'Shutdown'  'shutdown -h now' -b 'Restart' 'shutdown -r now' -b 'Logout' 'swaymsg exit' -b 'suspend' 'systemctl suspend' --background=#005566 --button-background=#009999 --button-border=#002b33 --border-bottom=#002b33",
      "on-click": "wlogout",
      "return-type": "json",
      "escape": true
    },
    "custom/launcher": {
        "format": "ΏθΡπ",                 // an icon (Font Awesome magnifying glass)
        "tooltip": "App Launcher",
        "on-click": "wofi --show drun", // command to run on click
        "interval": 0                  // no need to refresh
    },
    "custom/recorder": {
      "exec": "pgrep wf-recorder >/dev/null && echo REC",
      "interval": 1
    },
}
